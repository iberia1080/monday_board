<odoo noupdate="1">
    <record id="board_balance_caja_guadalajara" model="monday.board">
        <field name="name">Balance de Caja - Guadalajara</field>
        <field name="description">Tablero de caja configurado para Guadalajara.</field>
    </record>

    <record id="col_concepto" model="monday.board.column">
        <field name="board_id" ref="monday_board.board_balance_caja_guadalajara"/>
        <field name="name">CONCEPTO</field>
        <field name="code">concepto</field>
        <field name="sequence">10</field>
        <field name="field_type">text</field>
    </record>
    <record id="col_persona" model="monday.board.column">
        <field name="board_id" ref="monday_board.board_balance_caja_guadalajara"/>
        <field name="name">Persona</field>
        <field name="code">persona</field>
        <field name="sequence">20</field>
        <field name="field_type">user</field>
    </record>
    <record id="col_fecha_pago" model="monday.board.column">
        <field name="board_id" ref="monday_board.board_balance_caja_guadalajara"/>
        <field name="name">Fecha de Pago</field>
        <field name="code">fecha_pago</field>
        <field name="sequence">30</field>
        <field name="field_type">date</field>
    </record>
    <record id="col_hora_pago" model="monday.board.column">
        <field name="board_id" ref="monday_board.board_balance_caja_guadalajara"/>
        <field name="name">Hora de Pago</field>
        <field name="code">hora_pago</field>
        <field name="sequence">40</field>
        <field name="field_type">time</field>
    </record>
    <record id="col_movimiento" model="monday.board.column">
        <field name="board_id" ref="monday_board.board_balance_caja_guadalajara"/>
        <field name="name">Movimiento</field>
        <field name="code">movimiento</field>
        <field name="sequence">50</field>
        <field name="field_type">tag</field>
    </record>
    <record id="col_entrada" model="monday.board.column">
        <field name="board_id" ref="monday_board.board_balance_caja_guadalajara"/>
        <field name="name">Entrada</field>
        <field name="code">entrada</field>
        <field name="sequence">60</field>
        <field name="field_type">number</field>
        <field name="is_currency">1</field>
        <field name="currency_symbol">$</field>
    </record>
    <record id="col_salida" model="monday.board.column">
        <field name="board_id" ref="monday_board.board_balance_caja_guadalajara"/>
        <field name="name">Salida</field>
        <field name="code">salida</field>
        <field name="sequence">70</field>
        <field name="field_type">number</field>
        <field name="is_currency">1</field>
        <field name="currency_symbol">$</field>
    </record>
    <record id="col_compra" model="monday.board.column">
        <field name="board_id" ref="monday_board.board_balance_caja_guadalajara"/>
        <field name="name">Compra</field>
        <field name="code">compra</field>
        <field name="sequence">80</field>
        <field name="field_type">text</field>
    </record>
    <record id="col_sucursal" model="monday.board.column">
        <field name="board_id" ref="monday_board.board_balance_caja_guadalajara"/>
        <field name="name">Sucursal</field>
        <field name="code">sucursal</field>
        <field name="sequence">90</field>
        <field name="field_type">tag</field>
    </record>
    <record id="col_comprobante" model="monday.board.column">
        <field name="board_id" ref="monday_board.board_balance_caja_guadalajara"/>
        <field name="name">Comprobante</field>
        <field name="code">comprobante</field>
        <field name="sequence">100</field>
        <field name="field_type">attachment</field>
    </record>
    <record id="col_total_real" model="monday.board.column">
        <field name="board_id" ref="monday_board.board_balance_caja_guadalajara"/>
        <field name="name">Total Real</field>
        <field name="code">total_real</field>
        <field name="sequence">110</field>
        <field name="field_type">formula</field>
        <field name="formula_expression">entrada - salida if dinero == 'Realizado' else ''</field>
    </record>
    <record id="col_total_proyeccion" model="monday.board.column">
        <field name="board_id" ref="monday_board.board_balance_caja_guadalajara"/>
        <field name="name">Total Proyeccion</field>
        <field name="code">total_proyeccion</field>
        <field name="sequence">120</field>
        <field name="field_type">formula</field>
        <field name="formula_expression">entrada - salida if dinero != 'Pagado Transfer' else ''</field>
    </record>
    <record id="col_dinero" model="monday.board.column">
        <field name="board_id" ref="monday_board.board_balance_caja_guadalajara"/>
        <field name="name">Dinero</field>
        <field name="code">dinero</field>
        <field name="sequence">130</field>
        <field name="field_type">status</field>
    </record>
    <record id="col_status" model="monday.board.column">
        <field name="board_id" ref="monday_board.board_balance_caja_guadalajara"/>
        <field name="name">Status</field>
        <field name="code">status</field>
        <field name="sequence">140</field>
        <field name="field_type">status</field>
    </record>
    <record id="col_audita" model="monday.board.column">
        <field name="board_id" ref="monday_board.board_balance_caja_guadalajara"/>
        <field name="name">Audita</field>
        <field name="code">audita</field>
        <field name="sequence">150</field>
        <field name="field_type">status</field>
    </record>
    <record id="col_nota_auditoria" model="monday.board.column">
