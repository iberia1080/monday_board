<odoo>
    <record id="view_monday_board_column_tree" model="ir.ui.view">
        <field name="name">monday.board.column.tree</field>
        <field name="model">monday.board.column</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence"/>
                <field name="board_id"/>
                <field name="name"/>
                <field name="code"/>
                <field name="field_type"/>
                <field name="width"/>
                <field name="is_currency"/>
            </list>
        </field>
    </record>

    <record id="view_monday_board_column_form" model="ir.ui.view">
        <field name="name">monday.board.column.form</field>
        <field name="model">monday.board.column</field>
        <field name="arch" type="xml">
            <form string="Board Column">
                <sheet>
                    <group>
                        <group>
                            <field name="board_id"/>
                            <field name="name"/>
                            <field name="code"/>
                            <field name="sequence"/>
                        </group>
                        <group>
                            <field name="field_type"/>
                            <field name="width"/>
                            <field name="is_currency"/>
                            <field name="currency_symbol" invisible="not is_currency"/>
                        </group>
                    </group>
                    <group invisible="field_type != 'formula'">
                        <field name="formula_expression"/>
                    </group>
                    <group invisible="field_type != 'status'">
                        <field name="status_option_ids">
                            <list editable="bottom">
                                <field name="sequence" widget="handle"/>
                                <field name="name"/>
                                <field name="color"/>
                                <field name="is_default"/>
                            </list>
                        </field>
                    </group>
                    <group invisible="field_type != 'tag'">
                        <field name="tag_ids">
                            <list editable="bottom">
                                <field name="name"/>
                                <field name="color" widget="color_picker"/>
                            </list>
                        </field>
                    </group>
                    <group string="Security">
                        <field name="view_group_ids" widget="many2many_tags"/>
                        <field name="edit_group_ids" widget="many2many_tags"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_monday_board_column" model="ir.actions.act_window">
        <field name="name">Columns</field>
        <field name="res_model">monday.board.column</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
