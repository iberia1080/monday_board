<odoo>
    <record id="view_monday_board_import_wizard_form" model="ir.ui.view">
        <field name="name">monday.board.import.wizard.form</field>
        <field name="model">monday.board.import.wizard</field>
        <field name="arch" type="xml">
            <form string="Import Monday Board">
                <group>
                    <field name="target_board_id"/>
                    <field name="import_mode"/>
                </group>
                <group invisible="import_mode != 'api'">
                    <field name="monday_token" password="True"/>
                    <field name="monday_board_id"/>
                    <field name="api_version"/>
                </group>
                <group invisible="import_mode != 'json'">
                    <field name="monday_json" nolabel="1" placeholder='{"id":"123","name":"Board","columns":[],"items_page":{"items":[]}}'/>
                </group>
                <footer>
                    <button name="action_import" type="object" string="Import" class="btn-primary"/>
                    <button string="Cancel" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
